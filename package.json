{
  "name": "locallink",
  "version": "0.1.0",
  "description": "Local-first orchestration dashboard and MCP core",
  "main": "dist/cli.js",
  "packageManager": "pnpm@11.6.0",
  "bin": {
    "locallink": "./bin/locallink.js"
  },
  "files": [
    "bin",
    "dist",
    "docs",
    "README.md",
    ".env.example",
    "docker-compose.yml",
    "ecosystem.config.js",
    "Taskfile.yml"
  ],
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "node --test --import tsx test/**/*.test.ts",
    "build": "rm -rf public/assets/app && tsc -p frontend/tsconfig.json && vite build --config frontend/vite.config.ts && tsc -p tsconfig.json && rm -rf dist/public && mkdir -p dist && cp -r public dist/public",
    "build:frontend": "rm -rf public/assets/app && tsc -p frontend/tsconfig.json && vite build --config frontend/vite.config.ts",
    "prepack": "pnpm build",
    "start": "node ./bin/locallink.js web",
    "web": "node ./bin/locallink.js web",
    "serve": "node ./bin/locallink.js web",
    "mcp": "node ./bin/locallink.js mcp",
    "doctor": "node ./bin/locallink.js doctor",
    "snapshot": "node ./bin/locallink.js snapshot",
    "dev": "tsx src/cli.ts web",
    "dev:frontend": "vite --config frontend/vite.config.ts",
    "dev:mcp": "tsx src/cli.ts mcp",
    "dev:doctor": "tsx src/cli.ts doctor"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@babel/parser": "^8.0.4",
    "@fastify/static": "^10.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fastify": "^5.10.0",
    "locallink": "link:",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recast": "^0.23.12",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5"
  }
}
