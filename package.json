{
  "name": "locallink",
  "version": "0.1.0",
  "description": "Local-first orchestration dashboard and MCP core",
  "main": "dist/cli.js",
  "packageManager": "pnpm@11.6.0",
  "bin": {
    "locallink": "./bin/locallink.js"
  },
  "files": [
    "bin",
    "dist",
    "docs",
    "examples",
    "README.md"
  ],
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "node --test --import tsx test/**/*.test.ts",
    "build": "tsc -p tsconfig.json && rm -rf dist/public && mkdir -p dist && cp -r public dist/public",
    "prepack": "pnpm build",
    "start": "node ./bin/locallink.js --workspace examples/systems/local-dev api",
    "up": "node ./bin/locallink.js --workspace examples/systems/local-dev up",
    "down": "node ./bin/locallink.js --workspace examples/systems/local-dev down",
    "status": "node ./bin/locallink.js --workspace examples/systems/local-dev status",
    "ai": "node ./bin/locallink.js --workspace examples/systems/local-dev ai --json",
    "up:smoke": "node ./bin/locallink.js --workspace examples/systems/smoke up",
    "down:smoke": "node ./bin/locallink.js --workspace examples/systems/smoke down",
    "status:smoke": "node ./bin/locallink.js --workspace examples/systems/smoke status --json",
    "ai:smoke": "node ./bin/locallink.js --workspace examples/systems/smoke ai --json",
    "snapshot:smoke": "node ./bin/locallink.js --workspace examples/systems/smoke snapshot",
    "api": "node ./bin/locallink.js --workspace examples/systems/local-dev api",
    "dashboard": "node ./bin/locallink.js --workspace examples/systems/local-dev dashboard",
    "web": "node ./bin/locallink.js --workspace examples/systems/local-dev dashboard",
    "serve": "node ./bin/locallink.js --workspace examples/systems/local-dev dashboard",
    "mcp": "node ./bin/locallink.js --workspace examples/systems/local-dev mcp",
    "doctor": "node ./bin/locallink.js --workspace examples/systems/local-dev doctor",
    "snapshot": "node ./bin/locallink.js --workspace examples/systems/local-dev snapshot",
    "dev": "tsx src/cli.ts --workspace examples/systems/local-dev api",
    "dev:dashboard": "tsx src/cli.ts --workspace examples/systems/local-dev dashboard",
    "dev:mcp": "tsx src/cli.ts --workspace examples/systems/local-dev mcp",
    "dev:doctor": "tsx src/cli.ts --workspace examples/systems/local-dev doctor"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@babel/parser": "^7.29.7",
    "@fastify/static": "^9.1.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fastify": "^5.8.5",
    "locallink": "link:",
    "recast": "^0.23.11",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
