{
  "name": "locallink",
  "version": "0.1.0",
  "description": "Local-first orchestration dashboard and MCP core",
  "main": "dist/cli.js",
  "packageManager": "pnpm@11.6.0",
  "bin": {
    "locallink": "./bin/locallink.js"
  },
  "files": [
    "bin",
    "dist",
    "docs",
    "README.md",
    ".env.example",
    "docker-compose.yml",
    "ecosystem.config.js",
    "Taskfile.yml"
  ],
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "node --test --import tsx test/**/*.test.ts",
    "build": "tsc -p tsconfig.json && rm -rf dist/public && mkdir -p dist && cp -r public dist/public",
    "prepack": "pnpm build",
    "start": "node ./bin/locallink.js web",
    "web": "node ./bin/locallink.js web",
    "serve": "node ./bin/locallink.js web",
    "mcp": "node ./bin/locallink.js mcp",
    "doctor": "node ./bin/locallink.js doctor",
    "snapshot": "node ./bin/locallink.js snapshot",
    "dev": "tsx src/cli.ts web",
    "dev:mcp": "tsx src/cli.ts mcp",
    "dev:doctor": "tsx src/cli.ts doctor"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@babel/parser": "^7.29.7",
    "@fastify/static": "^9.1.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fastify": "^5.8.5",
    "locallink": "link:",
    "recast": "^0.23.11",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  }
}
